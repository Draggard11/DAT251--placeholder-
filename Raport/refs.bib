title = {Shedding light on the dark side – A systematic literature review of the issues in agile software development methodology use},
journal = {Journal of Systems and Software},
volume = {211},
pages = {111966},
year = {2024},
issn = {0164-1212},
doi = {https://doi.org/10.1016/j.jss.2024.111966},
